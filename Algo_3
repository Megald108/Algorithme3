VARIABLES
    n EST_DU_TYPE NOMBRE
    i EST_DU_TYPE NOMBRE
    produit EST_DU_TYPE NOMBRE

DEBUT_ALGORITHME
    AFFICHER "Entrez un entier n :"
    LIRE n

    produit PREND_LA_VALEUR 1

    POUR i ALLANT_DE 1 A n
        DEBUT_POUR
            produit PREND_LA_VALEUR produit * i
        FIN_POUR

    AFFICHER "Le produit des entiers de 1 à "
    AFFICHER n
    AFFICHER " est : "
    AFFICHER produit
FIN_ALGORITHME
